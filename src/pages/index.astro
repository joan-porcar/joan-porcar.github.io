---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 1. Obtener y ordenar los posts de forma cronológica (más recientes primero)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Tags principales definidos para el filtrado minimalista
const filterTags = ['Trading', 'Mindset', 'DARWINs', 'Tecnología', 'Reflexiones'];
---
<Layout title="Joan Porcar | Trading, Mercados y Comportamiento Humano">
    <main class="max-w-5xl mx-auto px-6 py-16 space-y-24">6 space-y-24">
        
        <!-- Zona HERO: Estructura Asimétrica en 2 Columnas (Estilo Seth Godin) -->
        <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            <!-- Columna Izquierda: Mensajes, Filosofía y Captación (7/12) -->
            <div class="lg:col-span-7 space-y-8">
                <div class="space-y-4">
                    <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight leading-none">
                        Conectando puntos desde la <span class="text-[#38BDF8]">trinchera</span>.
                    </h1>
                    <p class="text-lg md:text-xl text-[#94A3B8] leading-relaxed">
                        Descodifico DARWINs, sistemas de trading, sesgos y la cruda realidad de la industria. Escribo sobre mercados, tecnología y mi forma de ver la vida.
                    </p>
                </div>

                <!-- Caja de suscripción con blur sutil integrado con el fondo azul metálico -->
                <div class="p-6 bg-zinc-900/40 border border-zinc-800/80 rounded-xl backdrop-blur-sm space-y-4 shadow-xl shadow-black/30">
                    <div class="space-y-1">
                        <h3 class="text-white font-semibold text-base">Si te gusta 👉 <span class="not-italic font-normal"><em>Directo</em></span> a tu bandeja</h3>
                        <p class="text-xs text-zinc-400">Píldoras directas y contenido fresco, libre de alérgenos. Cero spam.</p>
                    </div>
                    <form class="flex flex-col sm:flex-row gap-3">
                        <input 
                            type="email" 
                            required 
                            placeholder="Tu email principal..." 
                            class="flex-1 bg-[#0A0A0C]/80 border border-zinc-700 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-500 focus:outline-none focus:border-[#38BDF8] transition-colors"
                        />
                        <button 
                            type="submit" 
                            class="bg-[#38BDF8] text-[#020617] font-bold text-sm px-6 py-3 rounded-lg hover:bg-white transition-all transform hover:-translate-y-0.5 active:translate-y-0 shadow-lg shadow-[#38BDF8]/10"
                        >
                            Suscribirse
                        </button>
                    </form>
                </div>
            </div>

            <!-- Columna Derecha: Contenedor de Retrato Estilizado con Enfoque Celeste (5/12) -->
            <div class="lg:col-span-5 flex justify-center lg:justify-end">
                <div class="relative p-3 rounded-[2.5rem] bg-zinc-900/20 border border-[#38BDF8]/40 shadow-xl shadow-[#38BDF8]/5 hover:border-[#38BDF8] transition-all duration-500 max-w-sm w-full group">
                    <div class="overflow-hidden rounded-[2rem] bg-zinc-950 aspect-[4/5] relative">
                        <img 
                            src="/images/Joan Porcar.png" 
                            alt="Joan Porcar" 
                            class="w-full h-full object-cover grayscale contrast-125 brightness-95 group-hover:grayscale-0 group-hover:scale-[1.02] transition-all duration-700"
                            loading="eager"
                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                        />
                        <!-- Fallback visual -->
                        <div class="hidden absolute inset-0 flex-col items-center justify-center p-6 text-center text-xs text-zinc-500 bg-zinc-900/80">
                            <span class="text-[#38BDF8] font-bold mb-2 text-sm">Joan Porcar.png</span>
                            Verifica que la carpeta <code class="text-white">public</code> esté fuera de <code class="text-white">src</code>.
                        </div>
                    </div>
                </div>
            </div>
            
        </section>

        <!-- Feed de Posts Cronológico -->
        <section class="space-y-12">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 border-b border-zinc-800/50 pb-6">
                <h2 class="text-2xl font-bold text-white tracking-tight">Bitácora Cronológica</h2>
                
                <div class="flex flex-wrap gap-2" id="tag-filters">
                    <button 
                        data-tag="all" 
                        class="tag-btn active-tag text-xs font-semibold px-3 py-1.5 rounded-full border border-[#38BDF8] bg-[#38BDF8] text-[#020617] transition-all"
                    >
                        Todos
                    </button>
                    {filterTags.map((tag) => (
                        <button 
                            data-tag={tag.toLowerCase()} 
                            class="tag-btn text-xs font-semibold px-3 py-1.5 rounded-full border border-zinc-800 text-zinc-400 hover:border-zinc-600 hover:text-white transition-all"
                        >
                            {tag}
                        </button>
                    ))}
                </div>
            </div>

            <div class="space-y-10" id="posts-container">
                {sortedPosts.map((post) => (
                    <article 
                        class="post-item group space-y-3 transition-opacity duration-300" 
                        data-tags={JSON.stringify(post.data.tags ? post.data.tags.map(t => t.toLowerCase()) : [])}
                    >
                        <div class="flex items-center gap-3 text-xs text-zinc-500">
                            <time datetime={post.data.pubDate.toISOString()}>
                                {post.data.pubDate.toLocaleDateString('es-ES', {
                                    year: 'numeric',
                                    month: 'long',
                                    day: 'numeric',
                                })}
                            </time>
                            <span>•</span>
                            <span>{post.data.readingTime || '5 min lectura'}</span>
                        </div>
                        
                        <h3 class="text-xl md:text-2xl font-bold text-white group-hover:text-[#38BDF8] transition-colors">
                            <a href={`/blog/${post.slug}/`}>
                                {post.data.title}
                            </a>
                        </h3>
                        
                        <p class="text-sm text-[#94A3B8] leading-relaxed max-w-3xl">
                            {post.data.description}
                        </p>

                        <div class="flex gap-2 pt-1">
                            {post.data.tags && post.data.tags.map((tag) => (
                                <span class="text-[10px] tracking-wider uppercase font-semibold text-zinc-400 bg-zinc-900/60 px-2 py-0.5 rounded border border-zinc-800/40">
                                    #{tag}
                                </span>
                            ))}
                        </div>
                    </article>
                ))}

                {sortedPosts.length === 0 && (
                    <p class="text-sm text-zinc-500 italic py-8">La bitácora está vacía por ahora. Próximamente nuevas píldoras.</p>
                )}
            </div>
        </section>

    </main>

    <script>
        const buttons = document.querySelectorAll('.tag-btn');
        const posts = document.querySelectorAll('.post-item');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                buttons.forEach(btn => {
                    btn.classList.remove('border-[#38BDF8]', 'bg-[#38BDF8]', 'text-[#020617]');
                    btn.classList.add('border-zinc-800', 'text-zinc-400');
                });
                
                button.classList.remove('border-zinc-800', 'text-zinc-400');
                button.classList.add('border-[#38BDF8]', 'bg-[#38BDF8]', 'text-[#020617]');

                const selectedTag = button.getAttribute('data-tag');

                posts.forEach(post => {
                    if (selectedTag === 'all') {
                        (post as HTMLElement).style.display = 'block';
                        setTimeout(() => (post as HTMLElement).style.opacity = '1', 10);
                    } else {
                        const postTags = JSON.parse(post.getAttribute('data-tags') || '[]');
                        if (postTags.includes(selectedTag)) {
                            (post as HTMLElement).style.display = 'block';
                            setTimeout(() => (post as HTMLElement).style.opacity = '1', 10);
                        } else {
                            (post as HTMLElement).style.opacity = '0';
                            setTimeout(() => (post as HTMLElement).style.display = 'none', 300);
                        }
                    }
                });
            });
        });
    </script>
</Layout>
