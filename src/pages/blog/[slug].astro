---
// src/pages/blog/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generar las rutas dinámicas para cada post en base a su slug
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. Recuperar la entrada específica de los props
const { entry } = Astro.props;
const { Content } = await entry.render();

// Formatear fecha de manera limpia
const formattedDate = entry.data.pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout 
  title={`${entry.data.title} | Joan Porcar`} 
  description={entry.data.description} 
  maxWidth="3xl"
>
  <style>
      /* Estilos específicos para inyectar el diseño premium al HTML renderizado desde Markdown */
      .prose p {
          margin-bottom: 1.5rem;
          color: #94A3B8;
          font-size: 1.05rem;
          line-height: 1.8;
      }
      .prose h2 {
          color: #FFFFFF;
          font-weight: 700;
          font-size: 1.75rem;
          margin-top: 2.5rem;
          margin-bottom: 1rem;
          letter-spacing: -0.025em;
      }
      .prose h3 {
          color: #FFFFFF;
          font-weight: 700;
          font-size: 1.4rem;
          margin-top: 2rem;
          margin-bottom: 0.75rem;
      }
      .prose em {
          color: #38BDF8;
          font-style: italic;
      }
      .prose strong {
          color: #FFFFFF;
          font-weight: 600;
      }
      .prose blockquote {
          border-left: 3px solid #38BDF8;
          padding-left: 1.25rem;
          font-style: italic;
          margin: 2rem 0;
          color: #CBD5E1;
      }
      .prose pre {
          background-color: #0A0A0C !important;
          border: 1px solid #334155/60;
          padding: 1.25rem;
          border-radius: 0.75rem;
          overflow-x: auto;
          margin: 2rem 0;
      }
      .prose code {
          font-size: 0.9rem;
          color: #E2E8F0;
      }
  </style>

    <!-- Contenedor Principal del Post -->
    <main class="max-w-3xl mx-auto px-6 py-16 space-y-10">
        
        <!-- Enlace de Retorno -->
        <a href="/" class="inline-flex items-center text-xs font-semibold text-[#38BDF8] hover:underline group gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver a la bitácora
        </a>

        <!-- Encabezado del Artículo -->
        <header class="space-y-4 border-b border-zinc-800/40 pb-8">
            <div class="flex items-center gap-3 text-xs text-zinc-500">
                <time datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
                <span>&bull;</span>
                <span>{entry.data.readingTime}</span>
            </div>
            
            <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight leading-tight">
                {entry.data.title}
            </h1>

            <div class="flex flex-wrap gap-2 pt-2">
                {entry.data.tags.map((tag) => (
                    <span class="text-[10px] tracking-wider uppercase font-semibold text-zinc-400 bg-zinc-900/60 px-2 py-0.5 rounded border border-zinc-800/40">
                        #{tag}
                    </span>
                ))}
            </div>
        </header>

        <!-- Contenido Inyectado (Markdown Dinámico) -->
        <article class="prose max-w-none">
            <Content />
        </article>

        <!-- Bloque de Cierre con Captación Integrada al final de la lectura -->
        <footer class="mt-16 pt-8 border-t border-zinc-800/50 space-y-6">
            <div class="p-6 bg-zinc-900/40 border border-zinc-800/80 rounded-xl backdrop-blur-sm space-y-4 shadow-xl shadow-black/30">
                <div class="space-y-1">
                    <h3 class="text-white font-semibold text-base">¿Te ha hecho pensar? Quédate cerca.</h3>
                    <p class="text-xs text-zinc-400">Ensayos analíticos y píldoras directas sin rodeos de gurú corporativo. Directo al grano.</p>
                </div>
                <a 
                    href="https://whatsapp.com/channel/TU_CANAL_AQUI" 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="flex items-center justify-center gap-2 w-full bg-[#38BDF8] text-[#020617] font-bold text-sm px-6 py-3.5 rounded-lg hover:bg-white transition-all transform hover:-translate-y-0.5 active:translate-y-0 shadow-lg shadow-[#38BDF8]/10"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-current" viewBox="0 0 24 24">
                        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.262 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.381 9.805-9.768.001-2.61-1.01-5.064-2.848-6.905C16.386 2.091 13.937 1.08 11.332 1.08 5.932 1.08 1.533 5.461 1.531 10.849c-.001 1.54.417 3.047 1.214 4.38l-.999 3.648 3.73-.977l-.001-.001zM17.432 14.1c-.318-.159-1.883-.93-2.174-1.036-.291-.106-.503-.159-.715.159-.211.318-.82.103-1.006.318-.185.215-.37.24-.688.082-.318-.159-1.341-.494-2.55-1.577-.94-.84-1.575-1.878-1.76-2.196-.185-.318-.02-.489.14-.647.143-.142.318-.371.477-.557.16-.186.212-.318.318-.53.106-.212.053-.397-.026-.557-.08-.159-.715-1.724-.98-2.36-.258-.62-.522-.536-.715-.546-.185-.01-.397-.012-.609-.012s-.556.08-.847.397c-.292.318-1.112 1.087-1.112 2.65 0 1.563 1.139 3.076 1.298 3.289.159.212 2.24 3.42 5.427 4.793.758.327 1.35.522 1.812.669.76.241 1.452.207 2.001.125.612-.091 1.883-.77 2.148-1.478.265-.707.265-1.314.185-1.442-.08-.127-.291-.207-.61-.366z"/>
                    </svg>
                    Directo a Tu WhatsApp
                </a>
            </div>
        </footer>

    </main>
</Layout>
