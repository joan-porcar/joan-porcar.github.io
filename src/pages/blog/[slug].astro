---
// src/pages/blog/[slug].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 1. Generar las rutas dinámicas para cada post en base a su slug
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

// 2. Recuperar la entrada específica de los props
const { entry } = Astro.props;
const { Content } = await entry.render();

// Formatear fecha de manera limpia
const formattedDate = entry.data.pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout 
  title={`${entry.data.title} | Joan Porcar`} 
  description={entry.data.description} 
  maxWidth="3xl"
>
  <style>
      /* Estilos específicos para inyectar el diseño premium al HTML renderizado desde Markdown */
      .prose p {
          margin-bottom: 1.5rem;
          color: #94A3B8;
          font-size: 1.05rem;
          line-height: 1.8;
      }
      .prose h2 {
          color: #FFFFFF;
          font-weight: 700;
          font-size: 1.75rem;
          margin-top: 2.5rem;
          margin-bottom: 1rem;
          letter-spacing: -0.025em;
      }
      .prose h3 {
          color: #FFFFFF;
          font-weight: 700;
          font-size: 1.4rem;
          margin-top: 2rem;
          margin-bottom: 0.75rem;
      }
      .prose em {
          color: #38BDF8;
          font-style: italic;
      }
      .prose strong {
          color: #FFFFFF;
          font-weight: 600;
      }
      .prose blockquote {
          border-left: 3px solid #38BDF8;
          padding-left: 1.25rem;
          font-style: italic;
          margin: 2rem 0;
          color: #CBD5E1;
      }
      .prose pre {
          background-color: #0A0A0C !important;
          border: 1px solid #334155/60;
          padding: 1.25rem;
          border-radius: 0.75rem;
          overflow-x: auto;
          margin: 2rem 0;
      }
      .prose code {
          font-size: 0.9rem;
          color: #E2E8F0;
      }
  </style>

    <!-- Contenedor Principal del Post -->
    <main class="max-w-3xl mx-auto px-6 py-16 space-y-10">
        
        <!-- Enlace de Retorno -->
        <a href="/" class="inline-flex items-center text-xs font-semibold text-[#38BDF8] hover:underline group gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transform group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Volver a la bitácora
        </a>

        <!-- Encabezado del Artículo -->
        <header class="space-y-4 border-b border-zinc-800/40 pb-8">
            <div class="flex items-center gap-3 text-xs text-zinc-500">
                <time datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
                <span>&bull;</span>
                <span>{entry.data.readingTime}</span>
            </div>
            
            <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight leading-tight">
                {entry.data.title}
            </h1>

            <div class="flex flex-wrap gap-2 pt-2">
                {entry.data.tags.map((tag) => (
                    <span class="text-[10px] tracking-wider uppercase font-semibold text-zinc-400 bg-zinc-900/60 px-2 py-0.5 rounded border border-zinc-800/40">
                        #{tag}
                    </span>
                ))}
            </div>
        </header>

        <!-- Contenido Inyectado (Markdown Dinámico) -->
        <article class="prose max-w-none">
            <Content />
        </article>

        <!-- Bloque de Cierre con Captación Integrada al final de la lectura -->
        <footer class="mt-16 pt-8 border-t border-zinc-800/50 space-y-6">
            <div class="p-6 bg-zinc-900/40 border border-zinc-800/80 rounded-xl backdrop-blur-sm space-y-4 shadow-xl shadow-black/30">
                <div class="space-y-1">
                    <h3 class="text-white font-semibold text-base">¿Te ha hecho pensar? Quédate cerca.</h3>
                    <p class="text-xs text-zinc-400">Ensayos analíticos y píldoras directas sin rodeos de gurú corporativo. Directo al grano.</p>
                </div>
                <form class="flex flex-col sm:flex-row gap-3">
                    <input 
                        type="email" 
                        required 
                        placeholder="Tu email principal..." 
                        class="flex-1 bg-[#0A0A0C]/80 border border-zinc-700 rounded-lg px-4 py-3 text-sm text-white placeholder-zinc-500 focus:outline-none focus:border-[#38BDF8] transition-colors"
                    />
                    <button 
                        type="submit" 
                        class="bg-[#38BDF8] text-[#020617] font-bold text-sm px-6 py-3 rounded-lg hover:bg-white transition-all transform hover:-translate-y-0.5 active:translate-y-0 shadow-lg shadow-[#38BDF8]/10"
                    >
                        Mantenerse al tanto
                    </button>
                </form>
            </div>
        </footer>

    </main>
</Layout>
